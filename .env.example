# Supabase frontend config
# Copy this file to .env.local when connecting the live database.
# Never place service_role keys in frontend variables.

VITE_SUPABASE_URL=https://olehulhxaxfqljbqwwgp.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Server-side AI config. Add these in Vercel Project Settings > Environment Variables.
# Never expose OPENAI_API_KEY as a VITE_ variable.
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
AI_MODEL=gpt-4o-mini
